# Production Environment Configuration
# Optimized for production deployment with security and performance

# Server Configuration
FRONTEND_PORT=3000
BACKEND_PORT=3001
BACKEND_HOST=0.0.0.0
CORS_ORIGIN=https://yourdomain.com
NODE_ENV=production

# Database Configuration
DB_TYPE=postgresql
DB_HOST=your-db-host.com
DB_PORT=5432
DB_NAME=lackadaisical_chat_prod
DB_USERNAME=app_user
DB_PASSWORD=CHANGE_THIS_PASSWORD
DB_SSL=true
DB_POOL_MIN=5
DB_POOL_MAX=20

# AI Provider Configuration
AI_PRIMARY_PROVIDER=anthropic
ANTHROPIC_API_KEY=your_anthropic_key_here
OPENAI_API_KEY=your_openai_key_here

# Fallback Provider
AI_FALLBACK_PROVIDER=openai

# Security
JWT_SECRET=CHANGE_THIS_TO_RANDOM_STRING_MINIMUM_32_CHARS
SESSION_SECRET=CHANGE_THIS_TO_RANDOM_STRING_MINIMUM_32_CHARS
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
ENABLE_HELMET=true
ENABLE_CORS=true

# Logging Configuration
LOG_LEVEL=info
LOG_TO_CONSOLE=false
LOG_TO_FILE=true
LOG_MAX_FILES=30
LOG_MAX_SIZE=50m

# Memory Configuration
MEMORY_MAX_CONTEXT_MESSAGES=100
MEMORY_CROSS_SESSION_ENABLED=true
MEMORY_AUTO_SUMMARIZE=true

# Performance
ENABLE_CACHING=true
CACHE_TTL_SECONDS=3600
ENABLE_COMPRESSION=true

# Backup Configuration
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_MAX_BACKUPS=60
BACKUP_COMPRESS=true

# Monitoring
ENABLE_HEALTH_CHECKS=true
HEALTH_CHECK_INTERVAL_MS=30000

# Production Features
ENABLE_HOT_RELOAD=false
ENABLE_DEBUG_ENDPOINTS=false
MOCK_AI_RESPONSES=false
