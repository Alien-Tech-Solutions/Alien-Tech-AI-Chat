# =============================================================================
# Lackadaisical AI Chat - Environment Configuration Template
# =============================================================================
# Copy to root directory as `.env` and configure your settings

# Server Configuration
FRONTEND_PORT=3000
BACKEND_PORT=3001
HOST=localhost
CORS_ORIGIN=http://localhost:3000

# AI Providers (Ollama is recommended for local use)
DEFAULT_AI_PROVIDER=ollama
OLLAMA_HOST=http://localhost:11434
OLLAMA_DEFAULT_MODEL=llama3.3:latest

# Optional External API Keys (leave blank if not using)
OPENAI_API_KEY=change-this-to-your-openai-key
ANTHROPIC_API_KEY=change-this-to-your-anthropic-key
GOOGLE_API_KEY=change-this-to-your-google-key
XAI_API_KEY=xai-change-this-to-your-xai-key

# AI Personality
AI_NAME=Lacky
AI_PERSONALITY_TRAITS=friendly,helpful,curious,empathetic,humorous

# Database
DATABASE_PATH=./database/chat.db
DATABASE_ENCRYPTION=false

# Features
STREAM_MODE=sse
ENABLE_MEMORY=true
ENABLE_LEARNING=true
ENABLE_JOURNALING=true
ENABLE_PLUGINS=true

# Security
RATE_LIMIT_MAX_REQUESTS=100
SESSION_SECRET=change-this-in-production

# Logging
LOG_LEVEL=info
LOG_TO_FILE=true
NODE_ENV=development 