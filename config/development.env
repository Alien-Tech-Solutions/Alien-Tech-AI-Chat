# Development Environment Configuration
# Optimized for local development with maximum debugging capabilities

# Server Configuration
FRONTEND_PORT=3000
BACKEND_PORT=3001
BACKEND_HOST=localhost
CORS_ORIGIN=http://localhost:3000
NODE_ENV=development

# Database Configuration
DB_TYPE=sqlite
DB_PATH=./database/chat_dev.db
DB_ENCRYPTED=false

# AI Provider Configuration  
AI_PRIMARY_PROVIDER=ollama
OLLAMA_HOST=http://localhost:11434
OLLAMA_DEFAULT_MODEL=llama3.2:latest

# Logging Configuration
LOG_LEVEL=debug
LOG_TO_CONSOLE=true
LOG_TO_FILE=true

# Memory Configuration
MEMORY_MAX_CONTEXT_MESSAGES=50
MEMORY_CROSS_SESSION_ENABLED=true
MEMORY_AUTO_SUMMARIZE=false

# Performance
ENABLE_CACHING=true
CACHE_TTL_SECONDS=300

# Development Features
ENABLE_HOT_RELOAD=true
ENABLE_DEBUG_ENDPOINTS=true
MOCK_AI_RESPONSES=false
