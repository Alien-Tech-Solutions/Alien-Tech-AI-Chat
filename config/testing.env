# Testing Environment Configuration
# Optimized for automated testing and CI/CD pipelines

# Server Configuration
FRONTEND_PORT=3002
BACKEND_PORT=3003
BACKEND_HOST=localhost
CORS_ORIGIN=http://localhost:3002
NODE_ENV=test

# Database Configuration
DB_TYPE=sqlite
DB_PATH=:memory:
DB_ENCRYPTED=false

# AI Provider Configuration (Mock for testing)
AI_PRIMARY_PROVIDER=ollama
OLLAMA_HOST=http://localhost:11434
OLLAMA_DEFAULT_MODEL=llama3.2:latest
MOCK_AI_RESPONSES=true

# Logging Configuration
LOG_LEVEL=error
LOG_TO_CONSOLE=true
LOG_TO_FILE=false

# Memory Configuration
MEMORY_MAX_CONTEXT_MESSAGES=20
MEMORY_CROSS_SESSION_ENABLED=false
MEMORY_AUTO_SUMMARIZE=false

# Performance
ENABLE_CACHING=false
CACHE_TTL_SECONDS=60

# Testing Features
ENABLE_HOT_RELOAD=false
ENABLE_DEBUG_ENDPOINTS=true
SKIP_RATE_LIMITING=true
FAST_MODE=true
