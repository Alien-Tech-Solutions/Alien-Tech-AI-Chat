# =============================================================================
# LACKADAISICAL AI CHAT - ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env and configure your settings
# All data is processed locally by default for privacy

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
FRONTEND_PORT=3000
BACKEND_PORT=3001
BACKEND_HOST=localhost
CORS_ORIGIN=http://localhost:3000

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# Database type: sqlite, postgresql, mysql
DB_TYPE=sqlite

# SQLite Configuration (default)
DB_PATH=./database/chat.db
DB_ENCRYPTED=false
DB_PASSPHRASE=

# PostgreSQL Configuration (optional)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=lackadaisical_chat
# DB_USERNAME=postgres
# DB_PASSWORD=your_password
# DB_SSL=false
# DB_POOL_MIN=2
# DB_POOL_MAX=10

# MySQL Configuration (optional)
# DB_HOST=localhost
# DB_PORT=3306
# DB_NAME=lackadaisical_chat
# DB_USERNAME=root
# DB_PASSWORD=your_password
# DB_SSL=false
# DB_POOL_MIN=2
# DB_POOL_MAX=10

# =============================================================================
# AI PROVIDER CONFIGURATION
# =============================================================================
# Primary AI provider: ollama, openai, anthropic, google, xai
AI_PRIMARY_PROVIDER=ollama

# Streaming mode: sse, ws, off
AI_STREAM_MODE=sse

# Model configurations
AI_MODEL_OLLAMA=llama2
AI_MODEL_OPENAI=gpt-4
AI_MODEL_ANTHROPIC=claude-3-sonnet-20240229
AI_MODEL_GOOGLE=gemini-pro
AI_MODEL_XAI=grok-beta

# Ollama configuration
OLLAMA_HOST=http://localhost:11434

# OPENAI_API_KEY=change-this-to-your-openai-key
# ANTHROPIC_API_KEY=change-this-to-your-anthropic-key
# GOOGLE_API_KEY=change-this-to-your-google-key
# XAI_API_KEY=change-this-to-your-xai-key

# =============================================================================
# PERSONALITY CONFIGURATION
# =============================================================================
PERSONALITY_NAME=Lacky
PERSONALITY_BASE_TRAITS=friendly,curious,helpful,witty
PERSONALITY_MOOD_VOLATILITY=0.3
PERSONALITY_EMPATHY_THRESHOLD=0.7

# =============================================================================
# PLUGIN CONFIGURATION
# =============================================================================
PLUGINS_ENABLED=weather,horoscope,poem-of-the-day
PLUGINS_AUTO_LOAD=true

# =============================================================================
# FEATURE FLAGS
# =============================================================================
FEATURE_JOURNALING=true
FEATURE_WEB_SEARCH=false
FEATURE_ENCRYPTION=false
FEATURE_DAILY_REMINDERS=false

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================
# Generate secure secrets for production
JWT_SECRET=your_jwt_secret_key_here_minimum_32_characters
SESSION_SECRET=your_session_secret_key_here_minimum_32_characters

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# =============================================================================
# DEVELOPMENT CONFIGURATION
# =============================================================================
NODE_ENV=development
DEBUG_MODE=false

# =============================================================================
# WEB SEARCH CONFIGURATION
# =============================================================================
WEB_SEARCH_TIMEOUT=30000
WEB_SEARCH_MAX_RESULTS=10

# =============================================================================
# JOURNAL CONFIGURATION
# =============================================================================
JOURNAL_REMINDER_TIME=21:00
JOURNAL_REMINDER_TIMEZONE=America/New_York

# =============================================================================
# PRODUCTION NOTES
# =============================================================================
# For production deployment:
# 1. Set NODE_ENV=production
# 2. Generate secure JWT_SECRET and SESSION_SECRET
# 3. Configure proper database (PostgreSQL recommended for production)
# 4. Set up proper CORS origins
# 5. Enable encryption if needed
# 6. Configure external AI providers if desired
# 7. Set up proper logging and monitoring 