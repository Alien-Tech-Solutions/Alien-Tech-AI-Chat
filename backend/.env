# Lackadaisical AI Chat - Environment Configuration
# Version: 2.0.0-alpha

# Server Configuration
FRONTEND_PORT=3000
BACKEND_PORT=3001
HOST=localhost

# Database Configuration
DATABASE_TYPE=sqlite
DATABASE_PATH=./database/chat.db

# AI Configuration
AI_PRIMARY_PROVIDER=ollama
AI_STREAM_MODE=sse
OLLAMA_HOST=http://localhost:11434

# Optional External API Keys (for using cloud AI providers)
# OPENAI_API_KEY=sk-your-key-here
# ANTHROPIC_API_KEY=sk-ant-your-key-here
# GOOGLE_API_KEY=your-key-here
# XAI_API_KEY=your-key-here

# Security Configuration (REQUIRED - generate random strings for production)
JWT_SECRET=lackadaisical-jwt-secret-change-in-production-32chars
SESSION_SECRET=lackadaisical-session-secret-change-production-32c

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# Development
NODE_ENV=development
DEBUG_MODE=false

# Features
FEATURE_JOURNALING=true
FEATURE_WEB_SEARCH=false
FEATURE_ENCRYPTION=false
FEATURE_DAILY_REMINDERS=false

# Plugins
PLUGINS_ENABLED=weather,horoscope,poem-of-the-day
PLUGINS_AUTO_LOAD=true
