# =============================================================================
# LACKADAISICAL AI CHAT - PRODUCTION ENVIRONMENT CONFIGURATION
# =============================================================================

# Database Configuration
DATABASE_PATH=./database/chat.db
DATABASE_TYPE=sqlite

# JWT Authentication Secrets (Production-Grade)
JWT_SECRET=change-to-your-key
JWT_REFRESH_SECRET=change-to-your-key

# Encryption Configuration
ENCRYPTION_KEY=change-to-your-key
BCRYPT_SALT_ROUNDS=12

# Server Configuration
NODE_ENV=development
PORT=3001
HOST=localhost
CORS_ORIGIN=http://localhost:3000

# AI Provider Configuration
OLLAMA_BASE_URL=http://localhost:11434
OPENAI_API_KEY=change-to-your-key
ANTHROPIC_API_KEY=change-to-your-key
GOOGLE_API_KEY=change-to-your-key
XAI_API_KEY=change-to-your-key

# WebSocket Configuration
WS_PORT=3002
WS_HOST=localhost

# Security Configuration
SESSION_SECRET=change-to-your-key
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=100

# Email Configuration (for password reset)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=noreply@lackadaisical-security.com

# Development Flags
DEBUG=false
VERBOSE_LOGGING=false
MOCK_AI_RESPONSES=false

# Plugin Configuration
PLUGINS_ENABLED=weather,horoscope,poem-of-the-day
PLUGINS_AUTO_RELOAD=true

# Memory Configuration
MEMORY_MAX_TOKENS=8000
MEMORY_COMPRESSION_THRESHOLD=1000
MEMORY_AUTO_ARCHIVE=false

# Performance Configuration
MAX_REQUEST_SIZE=10mb
MAX_CONCURRENT_REQUESTS=50
REQUEST_TIMEOUT=30000

# Backup Configuration
AUTO_BACKUP_ENABLED=true
BACKUP_INTERVAL_HOURS=24
BACKUP_RETENTION_DAYS=30

# =============================================================================
# SECURITY NOTES:
# - JWT secrets are 64-character hex strings for maximum entropy
# - Encryption key is 64-character hex for AES-256 compatibility
# - BCRYPT salt rounds set to 12 for optimal security/performance balance
# - All secrets should be regenerated for production deployment
# =============================================================================
